# ─────────────────────────────────────────────
# Slack Integration
# ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Note: SLACK_APP_TOKEN is NOT needed — socket_mode_enabled: false

# ─────────────────────────────────────────────
# n8n AI Agent Backend
# ─────────────────────────────────────────────
N8N_BASE_URL=https://your-n8n-instance-domain-here
# Optional shared secret for webhook security (set same value in n8n header auth)
N8N_WEBHOOK_SECRET=
# Public base URL of your n8n instance — used by n8n to build correct webhook URLs
# behind a reverse proxy (e.g. https://your-domain.com). Required for webhook delivery.
N8N_WEBHOOK_URL=https://your-domain.com
# Encryption key for n8n credential storage. Generate once with:
#   openssl rand -hex 32
# CRITICAL: keep this stable — changing it makes all stored credentials unreadable.
N8N_ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# Database (Postgres)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_password
POSTGRES_DB=lms_db

# ─────────────────────────────────────────────
# Cache (Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Google Sheets Backup (Agent 14)
# ─────────────────────────────────────────────
# The ID from the Google Sheets URL: /spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_BACKUP_ID=your-google-spreadsheet-id-here
# Slack Incoming Webhook URL for backup completion notifications
# Create one at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_ADMIN_WEBHOOK_URL=https://hooks.slack.com/services/your/admin/webhook
