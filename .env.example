# ─────────────────────────────────────────────────────────────────────────────
# RWRGroupSlackLMS — environment variable template
# Copy to .env and fill in all values before running docker compose up.
# NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Note: SLACK_APP_TOKEN is NOT needed — socket_mode_enabled: false

# ── n8n AI Agent Backend ─────────────────────────────────────────────────────
# URL the Slack app uses to call n8n webhooks.
# When running n8n via docker compose on the same host use: http://n8n:5678
# When using the hosted n8n instance use: https://n8n.srv1371300.hstgr.cloud
N8N_BASE_URL=http://n8n:5678

# Shared secret sent as X-Webhook-Secret header to n8n.
# Generate with: openssl rand -hex 32
# Set the same value as the "Header Auth" credential in n8n.
N8N_WEBHOOK_SECRET=your-webhook-secret-here

# Port n8n listens on (host-side).  Defaults to 5678.
N8N_PORT=5678

# Encryption key for n8n credentials stored in Postgres.
# CRITICAL: generate once and never change — changing it corrupts saved creds.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Public URL n8n uses when generating webhook trigger URLs in the editor.
# Set to the URL you use to access n8n (e.g. https://n8n.yourdomain.com).
N8N_WEBHOOK_PUBLIC_URL=http://localhost:5678

# Set to false when n8n is NOT served over HTTPS (e.g. plain HTTP proxy or
# local dev).  Set to true only when n8n is behind a TLS-terminating proxy.
N8N_SECURE_COOKIE=false

# ── Database (Postgres) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_password
POSTGRES_DB=lms_db

# ── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Sheets Backup (Agent 14) ─────────────────────────────────────────
# The ID from the Google Sheets URL: /spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_BACKUP_ID=your-google-spreadsheet-id-here
# Slack Incoming Webhook URL for backup completion notifications.
# Create one at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_ADMIN_WEBHOOK_URL=https://hooks.slack.com/services/your/admin/webhook
