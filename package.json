{
  "name": "rwrgroup-slack-lms",
  "version": "0.1.0",
  "description": "Slack-integrated Learning Management System for RWR Group",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "deploy": "node scripts/deploy.js",
    "db:migrate": "node scripts/migrate.js",
    "workflows:backup": "node scripts/backupWorkflows.js",
    "check:env-docs": "node scripts/check-env-docs.js"
  },
  "keywords": [
    "slack",
    "lms",
    "learning",
    "rwr-group"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@slack/bolt": "^3.17.1",
    "dotenv": "^16.4.1",
    "pg": "^8.11.3",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
