    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  u.slack_user_id,\n  u.display_name,\n  c.code   AS course_code,\n  c.title  AS course_title,\n  TO_CHAR(e.enrolled_at,  'YYYY-MM-DD HH24:MI:SS') AS enrolled_at,\n  CASE WHEN e.completed_at IS NOT NULL\n       THEN TO_CHAR(e.completed_at, 'YYYY-MM-DD HH24:MI:SS')\n       ELSE NULL END                               AS completed_at,\n  CASE WHEN e.completed_at IS NOT NULL\n       THEN 'Completed' ELSE 'In Progress' END     AS status\nFROM enrolments e\nJOIN users   u ON u.id = e.user_id\nJOIN courses c ON c.id = e.course_id\nORDER BY e.enrolled_at DESC",
        "options": {}
