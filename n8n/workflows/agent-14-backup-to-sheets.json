    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  table_name,\n  row_count,\n  TO_CHAR(NOW(), 'YYYY-MM-DD HH24:MI:SS') AS snapshot_at\nFROM (\n  SELECT 'users'        AS table_name, COUNT(*)::int AS row_count FROM users\n  UNION ALL\n  SELECT 'courses',                    COUNT(*)      FROM courses\n  UNION ALL\n  SELECT 'modules',                    COUNT(*)      FROM modules\n  UNION ALL\n  SELECT 'enrolments',                 COUNT(*)      FROM enrolments\n  UNION ALL\n  SELECT 'progress',                   COUNT(*)      FROM progress\n  UNION ALL\n  SELECT 'certificates',               COUNT(*)      FROM certificates\n) counts",
        "options": {}
      },
