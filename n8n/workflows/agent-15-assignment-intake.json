        -960,
        120
      ],
      "webhookId": "a15-assignment-intake-webhook"
    },
    {
      "parameters": {
        "jsCode": "const root = $json.body ?? $json;\nconst payload = typeof root.payload === 'string' ? JSON.parse(root.payload) : (root.payload || root);\nreturn [{ json: payload }];"
      },
      "id": "a1500000-0000-0000-0000-000000000002",
      "name": "Parse Interaction Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -760,
        120
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "leftValue": "={{ $json.type }}",
              "rightValue": "block_actions",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "leftValue": "={{ $json.actions[0].action_id }}",
              "rightValue": "nudge_assignment_icon",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1500000-0000-0000-0000-000000000003",
      "name": "Is Assignment Icon Click",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -560,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://slack.com/api/views.open",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SLACK_BOT_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "trigger_id": "={{ $json.trigger_id }}",
          "view": "={{ JSON.stringify({\n            type: 'modal',\n            callback_id: 'assignment_submission_modal',\n            title: { type: 'plain_text', text: 'Submit Assignment' },\n            submit: { type: 'plain_text', text: 'Save' },\n            close: { type: 'plain_text', text: 'Cancel' },\n            private_metadata: JSON.stringify({\n              user_id: $json.user.id,\n              lesson_id: JSON.parse($json.actions[0].value || '{}').lesson_id || '',\n              course_title: JSON.parse($json.actions[0].value || '{}').course_title || ''\n            }),\n            blocks: [\n              {\n                type: 'input',\n                block_id: 'assignment_link_block',\n                label: { type: 'plain_text', text: 'Assignment link (Google Doc/URL)' },\n                element: { type: 'plain_text_input', action_id: 'assignment_link_input', placeholder: { type: 'plain_text', text: 'https://...' } }\n              },\n              {\n                type: 'input',\n                block_id: 'assignment_screenshot_block',\n                optional: true,\n                label: { type: 'plain_text', text: 'Screenshot URL (optional)' },\n                element: { type: 'plain_text_input', action_id: 'assignment_screenshot_input', placeholder: { type: 'plain_text', text: 'https://...' } }\n              }\n            ]\n          }) }}"
        },
        "options": {}
      },
      "id": "a1500000-0000-0000-0000-000000000004",
      "name": "Open Assignment Modal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -360,
        40
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "leftValue": "={{ $json.type }}",
              "rightValue": "view_submission",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "leftValue": "={{ $json.view.callback_id }}",
              "rightValue": "assignment_submission_modal",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1500000-0000-0000-0000-000000000005",
      "name": "Is Assignment Modal Submit",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -360,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const meta = JSON.parse($json.view.private_metadata || '{}');\nconst values = $json.view.state.values || {};\nconst link = values.assignment_link_block?.assignment_link_input?.value || '';\nconst screenshot = values.assignment_screenshot_block?.assignment_screenshot_input?.value || '';\nconst date = new Date().toISOString().replace(/[:.]/g, '-');\nconst safeUser = String(meta.user_id || $json.user?.id || 'unknown').replace(/[^a-zA-Z0-9_-]/g, '_');\nconst safeLesson = String(meta.lesson_id || 'na').replace(/[^a-zA-Z0-9_-]/g, '_');\nconst auto_filename = `assignment_${safeUser}_lesson-${safeLesson}_${date}.json`;\nreturn [{ json: { user_id: safeUser, lesson_id: safeLesson, course_title: meta.course_title || '', assignment_link: link, screenshot_url: screenshot, auto_filename } }];"
      },
      "id": "a1500000-0000-0000-0000-000000000006",
      "name": "Build Auto Filename",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        220
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ASSIGNMENT_DRIVE_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json) }}",
        "options": {}
      },
